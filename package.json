{
  "name": "jkosi-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "db:migrate": "wrangler d1 execute jkosi-db --remote --file=./database/schema.sql",
    "db:migrate:local": "wrangler d1 execute jkosi-db --local --file=./database/schema.sql",
    "db:seed-admin": "node scripts/seed-admin.mjs > /tmp/seed-admin-tmp.sql && wrangler d1 execute jkosi-db --remote --file=/tmp/seed-admin-tmp.sql",
    "db:seed-admin:local": "node scripts/seed-admin.mjs > /tmp/seed-admin-tmp.sql && wrangler d1 execute jkosi-db --local --file=/tmp/seed-admin-tmp.sql"
  },
  "dependencies": {
    "motion": "^12.42.2",
    "next": "16.2.10",
    "ogl": "^1.0.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.110.0"
  }
}
