# Application Port (the host port Docker binds to, change if 3001 is already taken)
APP_PORT=3001

# Database configuration (Choose either Option A or Option B)

# Option A: Single PostgreSQL connection string URL
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/jkosi

# Option B: Separate PostgreSQL parameters (used by Docker Compose and custom VPS setups)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=jkosi

# Payload secret key (used for authentication encryption)
PAYLOAD_SECRET=your_payload_secret_key_here

# Public server URL (used for absolute URL routing and redirect resolutions)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
