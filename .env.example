# ─────────────────────────────────────────────────────────────────────────────
# JKOSI Environment Configuration
# Copy this file to .env and fill in your values before starting the app.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────

# Host port Docker maps to — change if this port is already taken on your server
APP_PORT=3001

# Full public URL of your app (used for redirects, links, and API callbacks)
# Local dev:  http://localhost:3000
# Production: http://your-server-ip:3001  or  https://yourdomain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
# All five variables are required. Do NOT use a connection URL string —
# define each parameter separately so they can be managed independently.

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_this_to_a_strong_password
DB_NAME=jkosi

# ── Payload CMS ───────────────────────────────────────────────────────────────
# Secret key used to sign admin session cookies and JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER change this after launch — it will invalidate all existing sessions.
PAYLOAD_SECRET=replace_with_a_long_random_secret_key
